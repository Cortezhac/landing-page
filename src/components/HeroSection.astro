---
import type { HeroTrans } from '../i18n/translations';

export interface Props {
  hero: HeroTrans;
}

const { hero } = Astro.props as Props;
---

<section class="max-w-7xl mx-auto px-gutter grid grid-cols-1 lg:grid-cols-12 gap-stack-lg items-center">
  <!-- ====== Left Column: Content ====== -->
  <div class="lg:col-span-7 space-y-stack-lg">
    <div class="space-y-stack-md">
      <!-- Available badge -->
      <div class="inline-flex items-center gap-2 px-3 py-1 bg-primary-container/10 border border-primary/20 rounded-full text-primary">
        <span class="relative flex h-2 w-2">
          <span class="animate-ping absolute inline-flex h-full w-full rounded-full bg-secondary opacity-75"></span>
          <span class="relative inline-flex rounded-full h-2 w-2 bg-secondary"></span>
        </span>
        <span class="font-label-caps text-label-caps uppercase">{hero.badge}</span>
      </div>

      <!-- Headline -->
      <h1 class="font-headline-lg-mobile md:font-headline-lg text-headline-lg-mobile md:text-headline-lg text-on-surface tracking-tight" set:html={hero.headline} />

      <!-- Description -->
      <p class="font-body-lg text-body-lg text-on-surface-variant max-w-2xl">
        {hero.description}
      </p>
    </div>

    <!-- Bento-style Summary Cards -->
    <div class="grid grid-cols-1 md:grid-cols-2 gap-stack-md">
      <div class="bento-card p-stack-md border border-outline-variant/40 rounded-xl shadow-sm">
        <h3 class="font-label-caps text-label-caps text-primary mb-2 flex items-center gap-2">
          <span class="material-symbols-outlined text-[18px]">terminal</span>
          {hero.backgroundTitle}
        </h3>
        <p class="font-body-sm text-body-sm text-on-surface-variant">
          {hero.backgroundText}
        </p>
      </div>
      <div class="bento-card p-stack-md border border-outline-variant/40 rounded-xl shadow-sm">
        <h3 class="font-label-caps text-label-caps text-primary mb-2 flex items-center gap-2">
          <span class="material-symbols-outlined text-[18px]">language</span>
          {hero.adaptabilityTitle}
        </h3>
        <p class="font-body-sm text-body-sm text-on-surface-variant">
          {hero.adaptabilityText}
        </p>
      </div>
    </div>

    <!-- CTA Actions -->
    <div class="flex flex-wrap gap-stack-md pt-stack-sm">
      <a href="#" class="inline-flex items-center gap-2 px-stack-lg py-3 bg-primary text-on-primary font-headline-sm text-headline-sm rounded-lg hover:opacity-90 transition-all duration-200 shadow-lg shadow-primary/20">
        {hero.ctaProjects}
        <span class="material-symbols-outlined">arrow_forward</span>
      </a>
      <a href="#" class="inline-flex items-center gap-2 px-stack-lg py-3 border border-primary text-primary font-headline-sm text-headline-sm rounded-lg hover:bg-primary/5 transition-all duration-200">
        {hero.ctaContact}
      </a>
    </div>

    <!-- Tech Stack Chips -->
    <div class="pt-stack-md">
      <p class="font-label-caps text-label-caps text-on-surface-variant mb-stack-sm uppercase">{hero.techStack}</p>
      <div class="flex flex-wrap gap-2">
        <span class="px-3 py-1 bg-surface-container-highest/50 text-primary font-label-caps text-label-caps rounded-full border border-primary/10">Laravel</span>
        <span class="px-3 py-1 bg-surface-container-highest/50 text-primary font-label-caps text-label-caps rounded-full border border-primary/10">Livewire</span>
        <span class="px-3 py-1 bg-surface-container-highest/50 text-primary font-label-caps text-label-caps rounded-full border border-primary/10">Filament</span>
        <span class="px-3 py-1 bg-surface-container-highest/50 text-primary font-label-caps text-label-caps rounded-full border border-primary/10">Tailwind</span>
        <span class="px-3 py-1 bg-tertiary-container/10 text-tertiary font-label-caps text-label-caps rounded-full border border-tertiary/20">AI Agents</span>
      </div>
    </div>
  </div>

  <!-- ====== Right Column: Visual / Code Mockup ====== -->
  <div class="lg:col-span-5 relative mt-stack-lg lg:mt-0">
    <!-- Background glow -->
    <div class="absolute -inset-4 bg-primary/5 rounded-full blur-3xl -z-10"></div>

    <!-- Code snippet card -->
    <div class="bg-surface-container-lowest border border-outline-variant/30 rounded-xl overflow-hidden code-glow shadow-xl">
      <!-- Title bar -->
      <div class="bg-surface-container-low px-4 py-2 flex items-center justify-between border-b border-outline-variant/20">
        <div class="flex gap-1.5">
          <div class="w-3 h-3 rounded-full bg-error/30"></div>
          <div class="w-3 h-3 rounded-full bg-tertiary/30"></div>
          <div class="w-3 h-3 rounded-full bg-secondary/30"></div>
        </div>
        <span class="font-code-sm text-code-sm text-on-surface-variant">{hero.codeFilename}</span>
        <button class="text-on-surface-variant hover:text-primary transition-colors">
          <span class="material-symbols-outlined text-[16px]">content_copy</span>
        </button>
      </div>

      <!-- Code lines -->
      <div class="p-6 font-code-md text-code-md space-y-2 overflow-x-auto bg-white dark:bg-surface-container-low">
        <div class="flex gap-4">
          <span class="text-outline/40 select-none">01</span>
          <code class="text-tertiary">namespace</code>
          <code class="text-on-surface">App\Http\Controllers;</code>
        </div>
        <div class="flex gap-4">
          <span class="text-outline/40 select-none">02</span>
          <code class="text-secondary">class</code>
          <code class="text-primary font-bold">BackendExpert</code>
        </div>
        <div class="flex gap-4">
          <span class="text-outline/40 select-none">03</span>
          <code class="text-on-surface-variant">{`{`}</code>
        </div>
        <div class="flex gap-4">
          <span class="text-outline/40 select-none">04</span>
          <code class="pl-4 text-secondary">public function</code>
          <code class="text-on-surface">handle(Request $req)</code>
          <code class="text-on-surface-variant">{`{`}</code>
        </div>
        <div class="flex gap-4">
          <span class="text-outline/40 select-none">05</span>
          <code class="pl-8 text-on-surface">return </code>
          <code class="text-tertiary">Laravel</code>
          <code class="text-on-surface">::robust();</code>
        </div>
        <div class="flex gap-4">
          <span class="text-outline/40 select-none">06</span>
          <code class="pl-4 text-on-surface-variant">{`}`}</code>
        </div>
        <div class="flex gap-4">
          <span class="text-outline/40 select-none">07</span>
          <code class="text-on-surface-variant">{`}`}</code>
        </div>
      </div>
    </div>

    <!-- Floating stats card -->
    <div class="absolute -bottom-6 -left-6 md:-left-12 bg-surface-container-lowest border border-outline-variant/30 p-stack-md rounded-xl shadow-2xl hidden md:block">
      <div class="flex items-center gap-4">
        <div class="bg-secondary/10 p-2 rounded-lg">
          <span class="material-symbols-outlined text-secondary">database</span>
        </div>
        <div>
          <p class="font-label-caps text-label-caps text-on-surface-variant">{hero.databaseEngine}</p>
          <p class="font-headline-sm text-headline-sm text-on-surface">{hero.databaseValue}</p>
        </div>
      </div>
    </div>

    <!-- Floating badge -->
    <div class="absolute -top-4 -right-4 bg-tertiary text-on-tertiary p-3 rounded-lg rotate-6 shadow-lg border border-tertiary/20 hidden lg:block">
      <span class="material-symbols-outlined block mb-1">directions_bike</span>
      <p class="font-label-caps text-label-caps font-bold">{hero.cyclingBadge}</p>
    </div>
  </div>
</section>
