---
import Icon from './Icon.astro';
import type { MarqueeItem } from '../i18n/translations';

export interface Props {
  items: MarqueeItem[];
}

const { items } = Astro.props as Props;
---

<section class="mt-section-padding border-y border-outline-variant/20 py-stack-lg bg-surface-container-low/50">
  <div class="max-w-7xl mx-auto px-gutter">
    <div class="flex flex-wrap justify-center md:justify-between items-center gap-stack-lg opacity-60 hover:opacity-100 transition-all duration-500">
      {
        items.map((item) => (
          <div class="flex items-center gap-2">
            <Icon name={item.icon} class="text-on-surface-variant" size={20} />
            <span class="font-label-caps text-label-caps text-on-surface-variant">{item.label}</span>
          </div>
        ))
      }
    </div>
  </div>
</section>
